# ── database ──────────────────────────────────────────────────────
# SQLite file path. Tests/e2e use their own files under ./data/ automatically.
DATABASE_URL=./data/wine.db

# ── auth (Better Auth) ────────────────────────────────────────────
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-a-real-secret
BETTER_AUTH_URL=http://localhost:3000

# ── LLM providers (operator-configured; at least one key required for real chat) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional operator-controlled OpenAI-compatible inference server (LM Studio, llama.cpp,
# vLLM, …) for open-weight models such as Gemma 4. Server-only; never client-supplied.
OPENAI_COMPATIBLE_BASE_URL=
# Optional bearer token for the OpenAI-compatible endpoint; local endpoints may leave empty.
OPENAI_COMPATIBLE_API_KEY=
# Models exposed in the app's model selector (provider:model-id, comma-separated).
# Provider prefixes: anthropic, openai, google, openai-compatible.
# Only models whose provider configuration is present above will actually appear.
AVAILABLE_MODELS=anthropic:claude-opus-4-8,anthropic:claude-sonnet-4-6,openai:gpt-5.2,google:gemini-3.5-flash,openai-compatible:gemma-4-12b-it
DEFAULT_MODEL=anthropic:claude-opus-4-8

# ── live web / availability search (specs/03, specs/08) ───────────
# NATIVE_WEB_SEARCH=1 (default) lets a native-search-capable exact model use its provider's
# built-in web search; 0 disables all native provider search (Tavily fallback still applies).
NATIVE_WEB_SEARCH=1
# Provider-neutral fallback search. Absent → the tutor degrades to general buying guidance.
TAVILY_API_KEY=

# ── testing ───────────────────────────────────────────────────────
# MOCK_LLM=1 swaps the registry for the deterministic mock (no network, no keys).
# Set automatically by the test scripts; useful manually for offline dev.
# MOCK_LLM=1
