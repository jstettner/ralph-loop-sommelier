{
  "name": "wine-trainer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "DATABASE_URL=./data/wine-e2e.db BETTER_AUTH_SECRET=e2e-secret-at-least-32-characters BETTER_AUTH_URL=http://127.0.0.1:3100 MOCK_LLM=1 next start -p 3100",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test:unit": "vitest run tests/unit",
    "test:integration": "DATABASE_URL=./data/wine-test.db BETTER_AUTH_SECRET=test-secret-at-least-32-characters BETTER_AUTH_URL=http://localhost:3000 MOCK_LLM=1 vitest run tests/integration",
    "test:e2e": "playwright test",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "db:seed": "node --import tsx src/db/seed.ts",
    "db:reset:test": "node --import tsx scripts/reset-test-db.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.82",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.46",
    "@ai-sdk/provider": "^2.0.3",
    "@ai-sdk/react": "^2.0.0",
    "ai": "^5.0.0",
    "better-auth": "^1.3.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.0",
    "msw": "^2.15.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
